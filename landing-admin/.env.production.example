# Copia a .env.production antes de `npm run build` (o `npm run deploy:admin` desde la raíz).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL pública del template (Firebase Hosting) para vista previa Local en producción
VITE_TEMPLATE_PREVIEW_URL=https://landing-template-9452e.web.app

VITE_FIREBASE_MEASUREMENT_ID=

# App Check — reCAPTCHA v3
VITE_RECAPTCHA_SITE_KEY=

# Email del primer root (opcional)
# VITE_BOOTSTRAP_ROOT_EMAIL=
