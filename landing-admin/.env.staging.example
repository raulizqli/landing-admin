# Copy to .env.staging — used by `vite build --mode staging` / deploy:stage.
# Point these at the Stage Firebase project (not Prod).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=landings-stage
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_TEMPLATE_PREVIEW_URL=https://landings-stage-template.web.app
VITE_MARKETING_URL=https://landings-stage-template.web.app/?pageId=leftsidedev
VITE_ADMIN_ORIGIN=https://landings-stage-admin.web.app

VITE_BOOTSTRAP_ROOT_EMAIL=
VITE_BILLING_SALES_EMAIL=

# App Check (optional on Stage)
VITE_RECAPTCHA_SITE_KEY=
# VITE_APP_CHECK_DEBUG_TOKEN=

VITE_FIREBASE_MEASUREMENT_ID=

# Leave empty on Stage cloud (do not point at emulators)
# VITE_FUNCTIONS_EMULATOR_HOST=
