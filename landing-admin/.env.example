VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Email del primer usuario root (opcional, solo desarrollo/bootstrap inicial)
VITE_BOOTSTRAP_ROOT_EMAIL=

# Dev: emulador de Cloud Functions (ej. 127.0.0.1:5001)
VITE_FUNCTIONS_EMULATOR_HOST=

# App Check — reCAPTCHA v3 (NO v2). Crear en https://www.google.com/recaptcha/admin/create
VITE_RECAPTCHA_SITE_KEY=

# Dev: token de depuración de App Check (Firebase Console → App Check → Manage debug tokens)
# Si se omite en dev, la consola del navegador imprimirá un token al cargar la app.
VITE_APP_CHECK_DEBUG_TOKEN=

# URL del template en Firebase Hosting (dev: http://localhost:5174)
VITE_TEMPLATE_PREVIEW_URL=

# Landing pública LeftSideDev (guests en `/` del admin redirigen aquí)
# Dev tip: http://localhost:5174/?pageId=leftsidedev
# Prod default si se omite: https://landing-template-9452e.web.app/?pageId=leftsidedev
VITE_MARKETING_URL=

# Opcional: GA4 por defecto si la landing no define analyticsMeasurementId en Firestore
VITE_FIREBASE_MEASUREMENT_ID=

# Email del CTA «Contact sales» del plan Enterprise
VITE_BILLING_SALES_EMAIL=
