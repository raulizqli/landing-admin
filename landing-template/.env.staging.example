# Copy to .env.staging — used by `vite build --mode staging` / deploy:stage.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=landings-stage
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Multi-domain Stage: leave empty and use customDomain / ?pageId=
# VITE_PAGINA_ID=

VITE_ADMIN_ORIGIN=https://landings-stage-admin.web.app
VITE_ADMIN_PUBLIC_URL=https://landings-stage-admin.web.app

VITE_FIREBASE_MEASUREMENT_ID=

# Keep ads off on Stage
# VITE_GOOGLE_ADS_CLIENT=
# VITE_GOOGLE_ADS_SLOT=

# App Check optional
# VITE_ENABLE_APP_CHECK=true
# VITE_RECAPTCHA_SITE_KEY=
