# Copia a .env.production antes de `npm run build` (o `npm run deploy:template` desde la raíz).
# Vite inyecta estas variables en el bundle en tiempo de compilación.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VITE_PAGINA_ID=maria-garcia
# Opcional en deploy multi-dominio (la app resuelve por customDomain). Requerido en modo un-sitio-por-cliente.

VITE_FIREBASE_MEASUREMENT_ID=

# URL del admin en Firebase Hosting (vista previa remota con postMessage)
# VITE_ADMIN_ORIGIN=https://landing-admin.web.app
