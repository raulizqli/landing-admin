VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_PAGINA_ID=

# App Check — desactivado por defecto en el template (sitio público de solo lectura).
# Activa solo cuando el dominio de Hosting/custom domain esté en reCAPTCHA v3 + App Check.
# VITE_ENABLE_APP_CHECK=true
VITE_RECAPTCHA_SITE_KEY=

# Dev: token de depuración App Check (opcional, solo si VITE_ENABLE_APP_CHECK=true)
VITE_APP_CHECK_DEBUG_TOKEN=

# Google Analytics 4 (Firebase Analytics) — ID de medición por deploy
VITE_FIREBASE_MEASUREMENT_ID=

# Opcional: origen del admin para postMessage en producción (ej. https://landing-admin.web.app)
# VITE_ADMIN_ORIGIN=
