# Copia a functions/.env (NO subir a git). Firebase Functions v2 carga este archivo al desplegar.

# URL pública del admin (success/cancel de Stripe / Mercado Pago)
ADMIN_PUBLIC_URL=https://landing-admin-9452e.web.app

# --- Stripe (suscripciones) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Se obtiene al crear el endpoint de webhook (ver README → Billing setup)
STRIPE_WEBHOOK_SECRET=whsec_...
# Products → Prices (modo recurring monthly) → price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
# Opcional (Enterprise suele ser manual):
# STRIPE_PRICE_ENTERPRISE=price_...

# --- Mercado Pago (preapproval / suscripciones) ---
# https://www.mercadopago.com.mx/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-...

# --- AI Assist ---
# AI_LITE_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# AI_LITE_MODEL=qwen2.5:7b
# AI_LITE_FALLBACK_PROVIDER=gemini
