# Copy values into functions/.env before `firebase use stage && firebase deploy --only functions`
# OR set the same keys as Firebase secrets / CI Environment "stage".
# Stage must use Stripe TEST + Mercado Pago TEST only.

ADMIN_PUBLIC_URL=https://landings-stage-admin.web.app

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

MERCADOPAGO_ACCESS_TOKEN=TEST-...

# AI Lite (prefer Ollama; mock fallback if unreachable)
AI_LITE_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_LITE_MODEL=qwen2.5:7b
AI_LITE_FALLBACK_PROVIDER=gemini
# GEMINI_API_KEY=
# GROQ_API_KEY=

